// NetWave Hotspot — Prisma Schema
// Supports PostgreSQL (Neon production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS & AUTH ──────────────────────────────────────────────────────────
model User {
  id               String    @id @default(uuid())
  email            String    @unique
  username         String    @unique
  password         String
  firstName        String
  lastName         String
  phone            String?
  role             String    @default("CUSTOMER")
  isActive         Boolean   @default(true)
  isVerified       Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  verifyToken      String?
  resetToken       String?
  resetTokenExp    DateTime?
  lastLogin        DateTime?
  avatar           String?
  address          String?
  notes            String?
  assignedRouter   String?
  planId           String?
  staticIp         String?
  macAddress       String?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  plan          InternetPlan?    @relation(fields: [planId], references: [id])
  payments      Payment[]
  vouchers      Voucher[]        @relation("VoucherCustomer")
  sessions      HotspotSession[]
  tickets       SupportTicket[]
  activities    ActivityLog[]
  notifications Notification[]
}

model RolePermission {
  id          String   @id @default(uuid())
  role        String   @unique
  permissions String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── ROUTERS ───────────────────────────────────────────────────────────────
model Router {
  id                   String    @id @default(uuid())
  name                 String
  ipAddress            String
  apiPort              Int       @default(8728)
  username             String
  password             String
  useSSL               Boolean   @default(false)
  isActive             Boolean   @default(true)
  isOnline             Boolean   @default(false)
  lastSeen             DateTime?
  location             String?
  description          String?
  identity             String?
  routerOSVersion      String?
  cpuLoad              Int?
  memoryUsage          Int?
  totalMemory          Int?
  uptime               String?
  hotspotRunning       Boolean   @default(false)
  wanActive            Boolean   @default(false)
  internetActive       Boolean   @default(false)
  totalUsers           Int?
  activeUsers          Int?
  connectionType       String    @default("PUBLIC_IP")
  vpnEndpoint          String?
  offlineSince         DateTime?
  reconnectAttempts    Int       @default(0)
  lastDisconnectReason String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  vouchers Voucher[]
  sessions HotspotSession[]
}

model RouterCustomer {
  routerId   String
  customerId String
  assignedAt DateTime @default(now())

  @@id([routerId, customerId])
}

// ─── INTERNET PLANS ────────────────────────────────────────────────────────
model InternetPlan {
  id            String   @id @default(uuid())
  name          String
  price         Float
  downloadSpeed Int
  uploadSpeed   Int
  dataLimit     Int?
  unlimited     Boolean  @default(false)
  validity      Int
  validityLabel String
  priority      Int      @default(8)
  burstSpeed    Int?
  description   String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vouchers  Voucher[]
  customers User[]
}

// ─── VOUCHERS ──────────────────────────────────────────────────────────────
model Voucher {
  id                   String    @id @default(uuid())
  code                 String    @unique
  prefix               String?
  qrCode               String?
  qrToken              String?   @unique
  planId               String
  routerId             String?
  customerId           String?
  price                Float
  status               String    @default("UNUSED")
  type                 String    @default("TIME")
  deviceLimit          Int       @default(1)
  activateOnFirstLogin Boolean   @default(true)
  activatedAt          DateTime?
  expiresAt            DateTime?
  dataUsed             Int       @default(0)
  batchId              String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  plan     InternetPlan    @relation(fields: [planId], references: [id])
  router   Router?         @relation(fields: [routerId], references: [id])
  customer User?           @relation("VoucherCustomer", fields: [customerId], references: [id])
  payment  Payment?
  sessions HotspotSession[]
}

// ─── HOTSPOT SESSIONS ──────────────────────────────────────────────────────
model HotspotSession {
  id           String    @id @default(uuid())
  userId       String?
  voucherId    String?
  routerId     String?
  macAddress   String?
  ipAddress    String?
  loginAt      DateTime  @default(now())
  logoutAt     DateTime?
  duration     Int?
  dataDownload Int       @default(0)
  dataUpload   Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  voucher Voucher? @relation(fields: [voucherId], references: [id])
  router  Router?  @relation(fields: [routerId], references: [id])
}

// ─── PAYMENTS ──────────────────────────────────────────────────────────────
model Payment {
  id          String   @id @default(uuid())
  reference   String   @unique
  userId      String?
  voucherId   String?  @unique
  planId      String?
  amount      Float
  currency    String   @default("NGN")
  gateway     String
  status      String   @default("PENDING")
  gatewayRef  String?
  gatewayData String?
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User?    @relation(fields: [userId], references: [id])
  voucher Voucher? @relation(fields: [voucherId], references: [id])
}

// ─── SETTINGS ──────────────────────────────────────────────────────────────
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  group     String   @default("general")
  updatedAt DateTime @updatedAt
}

// ─── LEGAL PAGES ───────────────────────────────────────────────────────────
model LegalPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ─── ANNOUNCEMENTS ─────────────────────────────────────────────────────────
model Announcement {
  id        String    @id @default(uuid())
  title     String
  content   String
  type      String    @default("INFO")
  isActive  Boolean   @default(true)
  showFrom  DateTime?
  showUntil DateTime?
  createdAt DateTime  @default(now())
}

// ─── ADVERTISEMENTS ────────────────────────────────────────────────────────
model Advertisement {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String?
  linkUrl   String?
  position  String   @default("CAPTIVE_TOP")
  isActive  Boolean  @default(true)
  clicks    Int      @default(0)
  views     Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── SUPPORT TICKETS ───────────────────────────────────────────────────────
model SupportTicket {
  id          String   @id @default(uuid())
  ticketNo    String   @unique
  userId      String
  subject     String
  description String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id])
  replies TicketReply[]
}

model TicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id])
}

// ─── NOTIFICATIONS ─────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── ACTIVITY LOGS ─────────────────────────────────────────────────────────
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ─── VOUCHER BATCHES ───────────────────────────────────────────────────────
model VoucherBatch {
  id        String   @id @default(uuid())
  name      String
  planId    String
  routerId  String?
  count     Int
  prefix    String?
  createdAt DateTime @default(now())
}
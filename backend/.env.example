# ═══════════════════════════════════════════════════════════════════════
#  NetWave Hotspot — Environment Variables
#  Copy to .env for local dev, or set in Render Dashboard for production
# ═══════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────────
# LOCAL (SQLite):
DATABASE_URL="file:./prisma/dev.db"
DB_PROVIDER="sqlite"

# PRODUCTION (Neon PostgreSQL — get from neon.tech):
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DB_PROVIDER="postgresql"

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Your URLs ─────────────────────────────────────────────────────────────────
# Replace with your actual deployed URLs after deployment:
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5000
CAPTIVE_PORTAL_URL=http://localhost:3000
ALLOWED_DOMAIN=localhost

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=7d

# ── Paystack (get from paystack.com → Settings → API Keys) ───────────────────
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# ── Flutterwave (get from flutterwave.com → Settings → API) ──────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=your_flw_webhook_hash

# ── SMTP Email (set via Admin → My Profile → Mail Settings after first login) ─
# These are fallback values. The admin panel settings take priority.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="NetWave Hotspot <your@gmail.com>"

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
